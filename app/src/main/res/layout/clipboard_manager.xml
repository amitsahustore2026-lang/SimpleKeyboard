<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/clipboard_manager"
    android:layout_width="match_parent"
    android:layout_height="@dimen/clipboard_manager_height"
    android:orientation="vertical"
    android:visibility="gone">

    <!-- Search + close + settings toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <EditText
            android:id="@+id/clip_search_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Search clipboard..."
            android:textColorHint="@color/special_key_normal"
            android:textColor="@color/on_surface"
            android:textSize="14sp"
            android:background="@drawable/key_bg"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:singleLine="true"
            android:imeOptions="actionDone" />

        <Button
            style="@style/SpecialKeyButton"
            android:layout_width="40dp"
            android:layout_height="32dp"
            android:layout_weight="0"
            android:layout_marginStart="4dp"
            android:text="⚙"
            android:tag="TOGGLE_CLIP_SETTINGS" />

        <Button
            style="@style/SpecialKeyButton"
            android:layout_width="40dp"
            android:layout_height="32dp"
            android:layout_weight="0"
            android:layout_marginStart="4dp"
            android:text="✕"
            android:tag="CLOSE_CLIPBOARD_MANAGER" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Browse panel: categories + list + bottom actions -->
        <LinearLayout
            android:id="@+id/clip_browse_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="visible">

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <Button style="@style/SpecialKeyButton" android:layout_width="60dp" android:layout_height="match_parent" android:text="All" android:tag="ALL" />
                    <Button style="@style/SpecialKeyButton" android:layout_width="70dp" android:layout_height="match_parent" android:text="Phone" android:tag="PHONE" />
                    <Button style="@style/SpecialKeyButton" android:layout_width="60dp" android:layout_height="match_parent" android:text="OTP" android:tag="OTP" />
                    <Button style="@style/SpecialKeyButton" android:layout_width="70dp" android:layout_height="match_parent" android:text="Email" android:tag="EMAIL" />
                    <Button style="@style/SpecialKeyButton" android:layout_width="60dp" android:layout_height="match_parent" android:text="URL" android:tag="URL" />
                    <Button style="@style/SpecialKeyButton" android:layout_width="90dp" android:layout_height="match_parent" android:text="Address" android:tag="ADDRESS" />
                    <Button style="@style/SpecialKeyButton" android:layout_width="70dp" android:layout_height="match_parent" android:text="Notes" android:tag="NOTES" />
                    <Button style="@style/SpecialKeyButton" android:layout_width="80dp" android:layout_height="match_parent" android:text="Others" android:tag="OTHERS" />
                </LinearLayout>
            </HorizontalScrollView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/clip_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="4dp"
                android:clipToPadding="false" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <Button style="@style/SpecialKeyButton" android:text="Clear All" android:tag="CLEAR_ALL_HISTORY" />
                <Button style="@style/SpecialKeyButton" android:text="Backup" android:tag="BACKUP_CLIPBOARD" />
                <Button style="@style/SpecialKeyButton" android:text="Restore" android:tag="RESTORE_CLIPBOARD" />
            </LinearLayout>
        </LinearLayout>

        <!-- Settings panel -->
        <LinearLayout
            android:id="@+id/clip_settings_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="6dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Maximum history size (50-1000)"
                android:textColor="@color/on_surface"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/clip_max_size_input"
                android:layout_width="120dp"
                android:layout_height="36dp"
                android:layout_marginTop="2dp"
                android:inputType="number"
                android:background="@drawable/key_bg"
                android:textColor="@color/on_surface"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Auto-delete non-pinned items after"
                android:textColor="@color/on_surface"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="2dp"
                android:orientation="horizontal">

                <Button style="@style/SpecialKeyButton" android:text="Never" android:tag="AUTO_DELETE_0" />
                <Button style="@style/SpecialKeyButton" android:text="1 Day" android:tag="AUTO_DELETE_24" />
                <Button style="@style/SpecialKeyButton" android:text="7 Days" android:tag="AUTO_DELETE_168" />
                <Button style="@style/SpecialKeyButton" android:text="30 Days" android:tag="AUTO_DELETE_720" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="📌 Pinned items are never deleted automatically."
                android:textColor="@color/special_key_normal"
                android:textSize="11sp" />

            <Button
                style="@style/SpecialKeyButton"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="8dp"
                android:text="🎛 Clipboard Formatter"
                android:tag="OPEN_FORMATTER" />

            <Button
                style="@style/AccentKeyButton"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="8dp"
                android:text="Save Settings"
                android:tag="SAVE_CLIP_SETTINGS" />
        </LinearLayout>

    </FrameLayout>

</LinearLayout>
