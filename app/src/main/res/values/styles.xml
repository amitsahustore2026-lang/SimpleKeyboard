<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="KeyButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">2dp</item>
        <item name="android:background">@drawable/key_bg</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:padding">0dp</item>
        <item name="android:gravity">center</item>
        <item name="android:elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="SpecialKeyButton" parent="KeyButton">
        <item name="android:background">@drawable/special_key_bg</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="AccentKeyButton" parent="KeyButton">
        <item name="android:background">@drawable/accent_key_bg</item>
        <item name="android:textColor">@color/on_primary_container</item>
    </style>

</resources>
